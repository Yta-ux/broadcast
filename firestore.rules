rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function tenantUserRef() {
      return /databases/$(database)/documents/tenantUsers/$(request.auth.uid);
    }

    function hasTenant() {
      return isAuthenticated() && exists(tenantUserRef());
    }

    function getUserTenantId() {
      return get(tenantUserRef()).data.tenantId;
    }

    function belongsToTenant() {
      return hasTenant() && resource.data.tenantId == getUserTenantId();
    }

    function incomingBelongsToTenant() {
      return hasTenant() && request.resource.data.tenantId == getUserTenantId();
    }

    // tenantUsers: user can read their own doc; create during signup
    match /tenantUsers/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if false;
    }

    // tenants
    match /tenants/{tenantId} {
      allow read, update: if hasTenant() && getUserTenantId() == tenantId;
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if false;
    }

    // connections
    match /connections/{connectionId} {
      allow read: if belongsToTenant();
      allow create: if incomingBelongsToTenant();
      allow update: if belongsToTenant() && incomingBelongsToTenant();
      allow delete: if belongsToTenant();
    }

    // contacts
    match /contacts/{contactId} {
      allow read: if belongsToTenant();
      allow create: if incomingBelongsToTenant();
      allow update: if belongsToTenant() && incomingBelongsToTenant();
      allow delete: if belongsToTenant();
    }

    // messages
    match /messages/{messageId} {
      allow read: if belongsToTenant();
      allow create: if incomingBelongsToTenant();
      allow update: if belongsToTenant() && incomingBelongsToTenant();
      allow delete: if belongsToTenant();
    }

    // deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
